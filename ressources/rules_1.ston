FamixCBContext{#contextFilter:'[ :collection | collection  select: [ :each | each isMethod ]]',#summary:'',#name:'allMethods'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity parameters size > 10])',#severity:Class[#FamixCBWarningSeverity],#summary:'',#name:'methods have more than 10 parameters'}FamixCBContext{#contextFilter:'[ :collection | collection select: [ :each | each isClass ]]',#summary:'',#name:'allClasses'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity methods size > 20 or: [ entity attributes size > 15 ] ])',#severity:Class[#FamixCBHintSeverity],#summary:'',#name:'classes have too many methods or attributes'}FamixCBContext{#contextFilter:'[ :collection | (collection select: [ :each | each isStub not and: [ each isFunction or: [ each isMethod or: [ each isClass ] ] ] ]) asSet ]',#summary:'',#name:'Should have docstrings'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity comments isEmpty or: [ (entity comments anySatisfy: [ :each | each sourceText includesSubstring: \'"""\' ]) not ] ])',#severity:Class[#FamixCBHintSeverity],#summary:'',#name:'entities are missing a docstring'}FamixCBContext{#contextFilter:'[ :collection |\r\tcollection select: [ :each |\r\t\teach isStub not and: [ each name isNotNil and: [ each isLocalVariable or: [ each class = FamixPythonParameter ] ] ] ] ]',#summary:'',#name:'local var & function parameters'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | (entity name matchesRegex: \'^[_a-z][a-z0-9_]*$\') not ])',#severity:Class[#FamixCBWarningSeverity],#summary:'',#name:'local variables and parameters don\'t respect naming convention'}FamixCBContext{#contextFilter:'[ :collection | collection select: [ :each | each isLocalVariable and: [ each isStub not ] ]]',#summary:'',#name:'local variables'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity incomingAccesses allSatisfy: [ :e | e isWrite ] ])',#severity:Class[#FamixCBWarningSeverity],#summary:'',#name:'local variables are unused'}FamixCBContext{#contextFilter:'[ :collection |\r\t| functions params |\r\tfunctions := collection select: [ :each | each isFunction or: [ each isMethod ] ].\r\r\tparams := ((functions select: [ :each | each parameters size > 0 ]) collect: [ :each | each parameters ]) flatCollect: [ :each | each ].\r\tparams ]',#summary:'',#name:'Functions and method params'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :param | \r\t"ignore self, underscore and kwargs param"\r\t(#( \'self\' \'_\' \'kwargs\') includes: param name) not \r\tand: [ param incomingAccesses allSatisfy: [ :e | e isWrite ] ] \r\t\r])',#severity:Class[#FamixCBWarningSeverity],#summary:'https://rules.sonarsource.com/python/RSPEC-1172/',#name:'function parameters are unused'}FamixCBContext{#contextFilter:'[ :collection |\rcollection select: [ :each | each isMethod and: [ each name matchesRegex: \'^__[A-Za-z0-9]([A-Za-z0-9_]*[A-Za-z0-9])?_?$\' ] ] ]',#summary:'a class-private method: two leading underscores, max one underscore at the end',#name:'class-private methods'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity incomingInvocations size = 0 ])',#severity:Class[#FamixCBHintSeverity],#summary:'https://rules.sonarsource.com/python/type/Code%20Smell/RSPEC-1144/',#name:'class-private methods are unused'}FamixCBContext{#contextFilter:'[ :collection | collection select: [ :each | each isAttribute ] ]',#summary:'',#name:'Attributes'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity name isNotNil and: [ entity name asLowercase = entity parentType name asLowercase ] ])',#severity:Class[#FamixCBHintSeverity],#summary:'https://rules.sonarsource.com/python/type/Code%20Smell/RSPEC-1700/',#name:'attributes duplicate their containing class name'}FamixCBContext{#contextFilter:'[ :collection | collection select: [ :each | each isModule ] ]',#summary:'',#name:'All modules'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | entity sourceAnchor lineCount > 1000 ])',#severity:Class[#FamixCBWarningSeverity],#summary:'https://rules.sonarsource.com/python/type/Code%20Smell/RSPEC-104/',#name:'files have more than 1000 LOC'}FamixCBContext{#contextFilter:'[ :collection | collection select: [ :each | each isFunction and: [ each isStub not and: [ each name isNotNil ] ] ] ]',#summary:'',#name:'Functions (named)'}FamixCBCondition{#query:'(FQSelectScriptQuery script: [ :entity | (entity name matchesRegex: \'^[a-z_][a-z0-9_]*$\') not ])',#severity:Class[#FamixCBHintSeverity],#summary:'https://rules.sonarsource.com/python/type/Code%20Smell/RSPEC-1542/',#name:'function names don\'t comply with naming convention'}OrderedCollection[0,1,0,3,0,5,0,7,0,9,0,11,0,13,0,15,0,17,0,19]